# darwin/zsh/aliases

alias cls='clear; ls'
alias cp='cp -i'
alias cx='chmod +x'
alias fssh='ssh -o '\''StrictHostKeyChecking no'\'''
alias g='grep'
alias gi='grep -i'
alias gir='grep -ir'
alias girl='grep -irl'
alias gl='grep -l'
alias gnc='grep --color=never'
alias gr='grep -r'
alias l1='/bin/ls -1'
alias la='ls -a'
alias ll='ls -l'
alias lla='ls -al'
alias llh='ls -lh'
alias ls='ls -FG'
alias mv='mv -i'
alias pc='perl -c'
alias pd='perldoc'
alias pdm='perldoc -m'
alias rm='rm -i'
alias si='svn info'
alias kill_fox='killall -m firefox'
alias kill_chrome="killall -m Chrome"

## Tommy Butler
alias ll='ls -Al'
alias la='ls -A'
alias lh='ls -Alh'
alias grep='grep --color=auto'
alias fgrep='fgrep --color=auto'
alias egrep='egrep --color=auto'
alias tstmp='date +%Y-%m-%d-%H.%M.%S'
alias vimclean="find . -iname '*sw[po]' -print -delete"
alias chme='sudo chown -R ${USER}:staff'
alias procperuser='ps ax -o user | sort | uniq -c | sort -nr'

# other
alias crontab="VIM_CRONTAB=true crontab"
alias vim=nvim
alias vi=vim

# docker
alias docker_rm_exited='docker rm $(docker ps -a | grep -i exited | awk "{print $1}")'


